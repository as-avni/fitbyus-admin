white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"3\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"10-12\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"60s\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                        </tr>\\n                        <tr>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"Lateral Raises\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"4\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"15\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                          <td className=\\\"px-4 py-3\\\"><input type=\\\"text\\\" defaultValue=\\\"45s\\\" className=\\\"w-full bg-transparent outline-none text-white\\\" /></td>\\n                        </tr>\\n                      </tbody>\\n                    </table>\\n                    <div className=\\\"p-3 bg-zinc-800/50 border-t border-zinc-800\\\">\\n                      <button className=\\\"text-sm text-brand font-medium hover:text-brand-hover flex items-center gap-1\\\">\\n                        <Plus className=\\\"w-4 h-4\\\" /> Add Exercise\\n                      </button>\\n                    </div>\\n                  </div>\\n                </div>\\n\\n                <div className=\\\"border border-zinc-800 rounded-xl overflow-hidden opacity-70 hover:opacity-100 transition-opa