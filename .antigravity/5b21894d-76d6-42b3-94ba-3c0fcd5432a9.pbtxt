        replacement_content: "      case \"messages\":\n        return (\n          <div className=\"h-[calc(100vh-8rem)] flex bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden\">\n            {/* Chat Sidebar */}\n            <div className=\"w-1/3 border-r border-zinc-800 hidden md:flex flex-col bg-zinc-950\">\n              <div className=\"p-4 border-b border-zinc-800\">\n                <div className=\"relative\">\n                  <Search className=\"w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500\" />\n                  <input \n                    type=\"text\" \n                    placeholder=\"Search messages...\" \n                    className=\"w-full pl-9 pr-4 py-2 bg-zinc-900 border border-zinc-800 rounded-lg text-sm text-white focus:ring-2 focus:ring-brand focus:border-brand outline-none\"\n                  />\n                </div>\n              </div>\n              <div className=\"flex-1 overflow-y-auto\">\n                {[\n                  { name: \"Rahul Sharma\", msg: \"Awesome, thanks Alex! The workouts...\", time: \"10:42 AM\", unread: false },\n                  { name: \"Neha Singh\", msg: \"Can I swap chicken for fish today?\", time: \"Yesterday\", unread: true },\n                  { name: \"Arjun Patel\", msg: \"Check-in submitted!\", time: \"Yesterday\", unread: false },\n                ].map((chat, i) => (\n                  <div key={i} className={`p-4 border-b border-zinc-800/50 cursor-pointer hover:bg-zinc-900 transition-colors ${i === 0 ? \'bg-zinc-900 border-l-4 border-l-brand\' : \'\'}`}>\n                    <div className=\"flex justify-between items-start mb-1\">\n                      <h4 className={`text-sm ${chat.unread ? \'font-bold text-white\' : \'font-medium text-zinc-300\'}`}>{chat.name}</h4>\n                      <span className=\"text-xs text-zinc-500\">{chat.time}</span>\n                    </div>\n                    <div className=\"flex justify-between items-center\">\n  