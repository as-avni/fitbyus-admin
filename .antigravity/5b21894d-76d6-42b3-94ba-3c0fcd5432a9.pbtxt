    end_line: 75
    content: "import { Link } from \"react-router-dom\";\nimport { Activity, ArrowRight, MessageCircle, Zap } from \"lucide-react\";\n\nexport default function Landing() {\n  return (\n    <div className=\"min-h-screen bg-zinc-50 flex flex-col items-center justify-center p-6\">\n      <div className=\"max-w-3xl w-full text-center space-y-8\">\n        <h1 className=\"text-5xl font-extrabold tracking-tight text-zinc-900 sm:text-6xl\">\n          FitByus\n        </h1>\n        <p className=\"text-xl text-zinc-600 max-w-2xl mx-auto\">\n          Get Your Personalized Diet Plan in 30 Seconds. Join the ultimate fitness transformation program.\n        </p>\n\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4 pt-8\">\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-emerald-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <Activity className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Generate Free Diet Plan</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">AI-powered personalized nutrition</p>\n          </Link>\n\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-indigo-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <Zap className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Start Transformation</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">Join our premium coaching program</p>\n          </Link>\n\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-orange-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <MessageCircle className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Talk to Coach</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">Get expert guidance and support</p>\n          </Link>\n        </div>\n\n        <div className=\"pt-12 flex items-center justify-center gap-4\">\n          <Link\n            to=\"/dashboard\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            User Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n          <span className=\"text-zinc-300\">|</span>\n          <Link\n            to=\"/coach\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            Coach Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n          <span className=\"text-zinc-300\">|</span>\n          <Link\n            to=\"/admin\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            Admin Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    raw_content: "import { Link } from \"react-router-dom\";\nimport { Activity, ArrowRight, MessageCircle, Zap } from \"lucide-react\";\n\nexport default function Landing() {\n  return (\n    <div className=\"min-h-screen bg-zinc-50 flex flex-col items-center justify-center p-6\">\n      <div className=\"max-w-3xl w-full text-center space-y-8\">\n        <h1 className=\"text-5xl font-extrabold tracking-tight text-zinc-900 sm:text-6xl\">\n          FitByus\n        </h1>\n        <p className=\"text-xl text-zinc-600 max-w-2xl mx-auto\">\n          Get Your Personalized Diet Plan in 30 Seconds. Join the ultimate fitness transformation program.\n        </p>\n\n        <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4 pt-8\">\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-emerald-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <Activity className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Generate Free Diet Plan</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">AI-powered personalized nutrition</p>\n          </Link>\n\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-indigo-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <Zap className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Start Transformation</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">Join our premium coaching program</p>\n          </Link>\n\n          <Link\n            to=\"/dashboard\"\n            className=\"flex flex-col items-center justify-center p-6 bg-white rounded-2xl shadow-sm border border-zinc-200 hover:border-orange-500 hover:shadow-md transition-all group\"\n          >\n            <div className=\"w-12 h-12 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\">\n              <MessageCircle className=\"w-6 h-6\" />\n            </div>\n            <h3 className=\"font-semibold text-zinc-900\">Talk to Coach</h3>\n            <p className=\"text-sm text-zinc-500 mt-2 text-center\">Get expert guidance and support</p>\n          </Link>\n        </div>\n\n        <div className=\"pt-12 flex items-center justify-center gap-4\">\n          <Link\n            to=\"/dashboard\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            User Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n          <span className=\"text-zinc-300\">|</span>\n          <Link\n            to=\"/coach\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            Coach Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n          <span className=\"text-zinc-300\">|</span>\n          <Link\n            to=\"/admin\"\n            className=\"text-sm font-medium text-zinc-600 hover:text-zinc-900 flex items-center gap-1\"\n          >\n            Admin Login <ArrowRight className=\"w-4 h-4\" />\n          </Link>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
