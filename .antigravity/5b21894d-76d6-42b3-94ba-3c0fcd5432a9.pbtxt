  <div className=\\\"space-y-6\\\">\\n            <div className=\\\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\\\">\\n              <div>\\n                <h2 className=\\\"text-2xl font-bold text-white\\\">User Management</h2>\\n                <p className=\\\"text-zinc-400\\\">Manage clients and assign coaches.</p>\\n              </div>\\n              <div className=\\\"relative w-full sm:w-64\\\">\\n                <Search className=\\\"w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500\\\" />\\n                <input \\n                  type=\\\"text\\\" \\n                  placeholder=\\\"Search clients...\\\" \\n                  className=\\\"w-full pl-9 pr-4 py-2 bg-zinc-900 border border-zinc-800 rounded-lg text-sm text-white focus:ring-2 focus:ring-brand outline-none\\\"\\n                />\\n              </div>\\n            </div>\\n\\n            <div className=\\\"bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden\\\">\\n              <div className=\\\"overflow-x-auto\\\">\\n                <table className=\\\"w-full text-sm text-left\\\">\\n                  <thead className=\\\"text-xs text-zinc-400 uppercase bg-zinc-950 border-b border-zinc-800\\\">\\n                    <tr>\\n                      <th className=\\\"px-6 py-4 font-medium\\\">Client Name</th>\\n                      <th className=\\\"px-6 py-4 font-medium\\\">Plan</th>\\n                      <th className=\\\"px-6 py-4 font-medium\\\">Goal</th>\\n                      <th className=\\\"px-6 py-4 font-medium\\\">Assigned Coach</th>\\n                      <th className=\\\"px-6 py-4 font-medium text-right\\\">Actions</th>\\n                    </tr>\\n                  </thead>\\n                  <tbody className=\\\"divide-y divide-zinc-800\\\">\\n                    {[\\n                      { name: \\\"Rahul Sharma\\\", plan: \\\"12 Week Coaching\\\", goal: \\\"Fat Loss\\\", coach: \\\"Alex\\\" },\\n                      { name: \\\"Priya Patel\\\", plan: \\\"Premium Coaching\\\", goal: \\\"Muscle Gain\\\", coach: \\\"Unassigned\\\" },\\n                      { name: \\\"Amit Kumar\\\", plan: \\\"Diet Plan\\\", goal: \\\"Maintenance\\\", coach: \\\"N/A\\\" },\\n                      { name: \\\"Neha Singh\\\", plan: \\\"12 Week Coaching\\\", goal: \\\"Fat Loss\\\", coach: \\\"Sarah\\\" },\\n                    ].map((client, i) => (\\n                      <tr key={i} className=\\\"hover:bg-zinc-800/50 transition-colors\\\">\\n                        <td className=\\\"px-6 py-4 font-medium text-white\\\">{client.name}</td>\\n                        <td className=\\\"px-6 py-4\\\">\\n                          <span className={`px-2 py-1 rounded-full text-xs font-medium ${\\n                            client.plan.includes(\'Coaching\') ? \'bg-indigo-500/10 text-indigo-400\' : \'bg-brand/10 text-brand\'\\n                          }`}>\\n                            {client.plan}\\n                          </span>\\n                        </td>\\n                        <td className=\\\"px-6 py-4 text-zinc-400\\\">{client.goal}</td>\\n                        <td className=\\\"px-6 py-4\\\">\\n                          {client.coach === \\\"Unassigned\\\" ? (\\n                            <select className=\\\"text-sm border border-zinc-700 rounded p-1 bg-zinc-800 text-brand font-medium focus:ring-2 focus:ring-brand outline-none\\\">\\n                              <option value=\\\"\\\">Assign Coach</option>\\n                              <option value=\\\"alex\\\">Alex</option>\\n                              <option value=\\\"sarah\\\">Sarah</option>\\n                            </select>\\n                          ) : (\\n                            <span className={client.coach === \\\"N/A\\\" ? \\\"text-zinc-500\\\" : \\\"text-white font-medium\\\"}>\\n                              {client.coach}\\n                            </span>\\n                          )}