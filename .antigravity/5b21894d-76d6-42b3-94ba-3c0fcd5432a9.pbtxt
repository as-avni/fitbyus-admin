                         <option value=\\\"\\\">Assign Coach</option>\\n                              <option value=\\\"alex\\\">Alex</option>\\n                              <option value=\\\"sarah\\\">Sarah</option>\\n                            </select>\\n                          ) : (\\n                            <span className={client.coach === \\\"N/A\\\" ? \\\"text-zinc-400\\\" : \\\"text-zinc-900 font-medium\\\"}>\\n                              {client.coach}\\n                            </span>\\n                          )}\\n                        </td>\\n                        <td className=\\\"px-6 py-4 text-right\\\">\\n                          <button className=\\\"text-zinc-400 hover:text-zinc-900\\\">\\n                            <MoreVertical className=\\\"w-4 h-4\\\" />\\n                          </button>\\n                        </td>\\n                      </tr>\\n                    ))}\\n                  </tbody>\\n                </table>\\n              </div>\\n            </div>\\n          </div>\"},{\"ReplacementContent\":\"          <div className=\\\"space-y-6\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-white\\\">Coach Management</h2>\\n              <p className=\\\"text-zinc-400\\\">Approve coaches and set their commission rates.</p>\\n            </div>\\n\\n            <div className=\\\"grid grid-cols-1 lg:grid-cols-2 gap-6\\\">\\n              <div className=\\\"bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden\\\">\\n                <div className=\\\"p-4 border-b border-zinc-800 bg-zinc-950 font-semibold text-white\\\">\\n                  Pending Approvals\\n                </div>\\n                <div className=\\\"divide-y divide-zinc-800\\\">\\n                  {[\\n                    { name: \\\"Vikram Singh\\\", exp: \\\"5 years\\\", cert: \\\"ACE Certified\\\" },\\n                    { name: \\\"Anjali Desai\\\", exp: \\\"3 years\\\", cert: \\\"ISSA Certified\\\" },\\n                  ].map((coach, i) => (\\n                    <div key={i} className=\\\"p-4 flex items-center justify-between\\\">\\n                      <div className=\\\"flex items-center gap-3\\\">\\n                        <div className=\\\"w-10 h-10 bg-zinc-800 rounded-full flex items-center justify-center text-zinc-400 font-bold\\\">\\n                          {coach.name.charAt(0)}\\n                        </div>\\n                        <div>\\n                          <h4 className=\\\"font-medium text-white\\\">{coach.name}</h4>\\n                          <p className=\\\"text-xs text-zinc-500\\\">{coach.exp} exp \342\200\242 {coach.cert}</p>\\n                        </div>\\n                      </div>\\n                      <div className=\\\"flex gap-2\\\">\\n                        <button className=\\\"p-1.5 text-brand bg-brand/10 rounded hover:bg-brand/20\\\">\\n                          <CheckCircle className=\\\"w-5 h-5\\\" />\\n                        </button>\\n                        <button className=\\\"p-1.5 text-red-500 bg-red-500/10 rounded hover:bg-red-500/20\\\">\\n                          <XCircle className=\\\"w-5 h-5\\\" />\\n                        </button>\\n                      </div>\\n                    </div>\\n                  ))}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden\\\">\\n                <div className=\\\"p-4 border-b border-zinc-800 bg-zinc-950 font-semibold text-white\\\">\\n                  Active Coaches\\n                </div>\\n                <div className=\\\"divide-y divide-zinc-800\\\">\\n                  {[\\n                    { name: \\\"Alex\\\", clients: 45, comm: 30 },\\n                    { name: \\\"Sarah\\\", clients: 32, comm: 35 },\\n                  ].map((coach, i) => (\\n                    <div key={i} className=\\\"p-4 flex items-center justify-between\\\">\\n                      <div className=\\\"flex items-center gap-3\\\">\\n                        <div className=\\\"w-10 h-10 bg-brand/10 rounded-full flex items-center justify-center text-brand font-bold\\\">\\n                          {coach.name.charAt(0)}\\n                        </div>\\n                        <div>\\n                          <h4 className=\\\"font-medium text-white\\\">{coach.name}</h4>\\n                          <p className=\\\"text-xs text-zinc-500\\\">{coach.clients} Active Clients</p>\\n                        </div>\\n                      </div>\\n                      <div className=\\\"flex items-center gap-2\\\">\\n                        <label className=\\\"text-xs text-zinc-500\\\">Comm. %</label>\\n                        <input \\n                          type=\\\"number\\\" \\n                          defaultValue={coach.comm} \\n                          className=\\\"w-16 p-1 text-sm bg-zinc-800 border border-zinc-700 rounded text-center text-white focus:ring-2 focus:ring-brand outline-none\\\"\\n                        />\\n                      </div>\\n                    </div>\\n                  ))}\\n                </div>\\n              </div>\\n            </div>\\n          </div>\",\"TargetContent\":\"          <div className=\\\"space-y-6\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Coach Management</h2>\\n              <p className=\\\"text-zinc-500\\\">Approve coaches and set their commission rates.</p>\\n            </div>\\n\\n            <div className=\\\"grid grid-cols-1 lg:grid-cols-2 gap-6\\\">\\n              <div className=\\\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\\\">\\n                <div className=\\\"p-4 border-b border-zinc-200 bg-zinc-50 font-semibold text-zinc-900\\\">\\n                  Pending Approvals\\n                </div>\\n                <div className=\\\"divide-y divide-zinc-100\\\"