\\n              return (\\n                <button\\n                  key={tab.id}\\n                  onClick={() => {\\n                    setActiveTab(tab.id);\\n                    setIsSidebarOpen(false);\\n                  }}\\n                  className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${\\n                    isActive \\n                      ? \\\"bg-brand text-black\\\" \\n                      : \\\"text-zinc-400 hover:bg-zinc-900 hover:text-white\\\"\\n                  }`}\\n                >\\n                  <Icon className={`w-5 h-5 ${isActive ? \\\"text-black\\\" : \\\"text-zinc-500\\\"}`} />\\n                  {tab.label}\\n                </button>\\n              );\\n            })}\\n          </nav>\\n        </div>\\n\\n        <div className=\\\"absolute bottom-0 left-0 right-0 p-4 border-t border-zinc-800\\\">\\n          <Link to=\\\"/\\\" className=\\\"w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-400 hover:bg-zinc-900 hover:text-white transition-colors\\\">\\n            <LogOut className=\\\"w-5 h-5 text-zinc-500\\\" />\\n            Sign Out\\n          </Link>\\n        </div>\\n      </aside>\\n\\n      {/* Main Content */}\\n      <main className=\\\"flex-1 flex flex-col min-w-0 overflow-hidden\\\">\\n        <header className=\\\"bg-zinc-950 border-b border-zinc-800 p-4 flex items-center md:hidden\\\">\\n          <button onClick={() => setIsSidebarOpen(true)} className=\\\"p-2 -ml-2 text-zinc-400\\\">\\n            <Menu className=\\\"w-6 h-6\\\" />\\n          </button>\\n          <span className=\\\"font-bold text-lg ml-2 text-white\\\">FitByus Admin</span>\\n        </header>\\n        <div className=\\\"flex-1 overflow-y-auto p-4 md:p-8\\\">\\n          {renderContent()}\\n        </div>\\n      </main>\\n    </div>\\n  );\",\"TargetContent\":\"  return (\\n    <div className=\\\"min-h-screen bg-zinc-50 flex\\\">\\n     