=\\\"w-full p-2 bg-zinc-800 border border-zinc-700 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none font-semibold text-white\\\" />\\n                    </div>\\n                    <div className=\\\"space-y-1\\\">\\n                      <label className=\\\"text-xs font-medium text-zinc-500 uppercase tracking-wider\\\">Protein (g)</label>\\n                      <input type=\\\"number\\\" defaultValue={160} className=\\\"w-full p-2 bg-zinc-800 border border-zinc-700 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none font-semibold text-white\\\" />\\n                    </div>\\n                    <div className=\\\"space-y-1\\\">\\n                      <label className=\\\"text-xs font-medium text-zinc-500 uppercase tracking-wider\\\">Carbs (g)</label>\\n                      <input type=\\\"number\\\" defaultValue={220} className=\\\"w-full p-2 bg-zinc-800 border border-zinc-700 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none font-semibold text-white\\\" />\\n                    </div>\\n                    <div className=\\\"space-y-1\\\">\\n                      <label className=\\\"text-xs font-medium text-zinc-500 uppercase tracking-wider\\\">Fat (g)</label>\\n                      <input type=\\\"number\\\" defaultValue={70} className=\\\"w-full p-2 bg-zinc-800 border border-zinc-700 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none font-semibold text-white\\\" />\\n                    </div>\\n                  </div>\\n                </div>\\n\\n                <div className=\\\"bg-zinc-900 rounded-2xl border border-zinc-800 overflow-hidden\\\">\\n                  <div className=\\\"p-4 border-b border-zinc-800 flex justify-between items-center bg-zinc-900/50\\\">\\n                    <h3 className=\\\"font-semibold text-white\\\">Meals</h3>\\n                    <button className=\\\"text-sm bg-zinc-800 border border-zinc-700 px-3 py-1.5 rounded-lg font-m