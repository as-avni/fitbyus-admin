            onChange={e => setProfile({...profile, email: e.target.value})} \n              className=\"w-full p-2 bg-zinc-950 border border-zinc-800 rounded-lg focus:ring-2 focus:ring-brand outline-none text-white\" \n            />\n          </div>\n        </div>\n\n        <div className=\"space-y-4 pt-4\">\n          <h3 className=\"text-lg font-semibold text-white border-b border-zinc-800 pb-2\">Change Password</h3>\n          <div className=\"space-y-2\">\n            <label className=\"text-sm font-medium text-zinc-400\">Current Password</label>\n            <input \n              type=\"password\" \n              value={profile.currentPassword} \n              onChange={e => setProfile({...profile, currentPassword: e.target.value})} \n              className=\"w-full p-2 bg-zinc-950 border border-zinc-800 rounded-lg focus:ring-2 focus:ring-brand outline-none text-white\" \n            />\n          </div>\n          <div className=\"space-y-2\">\n            <label className=\"text-sm font-medium text-zinc-400\">New Password</label>\n            <input \n              type=\"password\" \n              value={profile.newPassword} \n              onChange={e => setProfile({...profile, newPassword: e.target.value})} \n              className=\"w-full p-2 bg-zinc-950 border border-zinc-800 rounded-lg focus:ring-2 focus:ring-brand outline-none text-white\" \n            />\n          </div>\n          <div className=\"space-y-2\">\n            <label className=\"text-sm font-medium text-zinc-400\">Confirm New Password</label>\n            <input \n              type=\"password\" \n              value={profile.confirmPassword} \n              onChange={e => setProfile({...profile, confirmPassword: e.target.value})} \n              className=\"w-full p-2 bg-zinc-950 border border-zinc-800 rounded-lg focus:ring-2 focus:ring-brand outline-none text-white\" \n            />\n          </div>\n        </div>\n\n        <button className=\"w-full bg-brand text-black p