    tool_call {
      id: "jq6lrsvq"
      name: "edit_file"
      arguments_json: "{\"Instruction\":\"Refactor UserDashboard to use new components and apply the brand theme\",\"ReplacementContent\":\"import { useState } from \\\"react\\\";\\nimport { \\n  User, \\n  Utensils, \\n  Dumbbell, \\n  TrendingUp, \\n  CalendarCheck, \\n  MessageSquare, \\n  CreditCard,\\n  LogOut,\\n  Menu,\\n  X,\\n  FileText\\n} from \\\"lucide-react\\\";\\nimport { Link } from \\\"react-router-dom\\\";\\n\\nimport ProfileSetup from \'../components/user/ProfileSetup\';\\nimport AIDietGenerator from \'../components/user/AIDietGenerator\';\\nimport PersonalDietPlan from \'../components/user/PersonalDietPlan\';\\nimport WorkoutPlan from \'../components/user/WorkoutPlan\';\\nimport ProgressTracker from \'../components/user/ProgressTracker\';\\nimport WeeklyCheckin from \'../components/user/WeeklyCheckin\';\\nimport Chat from \'../components/user/Chat\';\\nimport Payment from \'../components/user/Payment\';\\n\\nexport default function UserDashboard() {\\n  const [activeTab, setActiveTab] = useState(\\\"profile\\\");\\n  const [isSidebarOpen, setIsSidebarOpen] = useState(false);\\n\\n  const tabs = [\\n    { id: \\\"profile\\\", label: \\\"Profile Setup\\\", icon: User },\\n    { id: \\\"diet\\\", label: \\\"AI Diet Generator\\\", icon: Utensils },\\n    { id: \\\"personal-diet\\\", label: \\\"Coach Diet Plan\\\", icon: FileText },\\n    { id: \\\"workout\\\", label: \\\"Workout Plan\\\", icon: Dumbbell },\\n    { id: \\\"progress\\\", label: \\\"Progress Tracker\\\", icon: TrendingUp },\\n    { id: \\\"checkin\\\", label: \\\"Weekly Check-in\\\", icon: CalendarCheck },\\n    { id: \\\"chat\\\", label: \\\"Chat with Coach\\\", icon: MessageSquare },\\n    { id: \\\"payment\\\", label: \\\"Payment System\\\", icon: CreditCard },\\n  ];\\n\\n  const renderContent = () => {\\n    switch (activeTab) {\\n      case \\\"profile\\\":\\n        return <ProfileSetup />;\\n      case \\\"diet\\\":\\n        return <AIDietGenerator />;\\n      case \\\"personal-diet\\\":\\n        return <PersonalDietPlan />;\\n      case \\\"workout\\\":\\n        return <WorkoutPlan />;\\n      case \\\"progress\\\":\\n        return <ProgressTracker />;\\n      case \\\"checkin\\\":\\n        return <WeeklyCheckin />;\\n      case \\\"chat\\\":\\n        return <Chat />;\\n      case \\\"payment\\\":\\n        return <Payment />;\\n      default:\\n        return <ProfileSetup />;\\n    }\\n  };\\n\\n  return (\\n    <div className=\\\"min-h-screen bg-[#09090b] text-zinc-50 flex\\\">\\n      {/* Mobile Sidebar Overlay */}\\n      {isSidebarOpen && (\\n        <div \\n          className=\\\"fixed inset-0 bg-black/50 z-20 md:hidden\\\"\\n          onClick={() => setIsSidebarOpen(false)}\\n        />\\n      )}\\n\\n      {/* Sidebar */}\\n      <aside className={`\\n        fixed inset-y-0 left-0 z-30 w-64 bg-zinc-950 border-r border-zinc-900 transform transition-transform duration-200 ease-in-out md:relative md:translate-x-0\\n        ${isSidebarOpen ? \'translate-x-0\' : \'-translate-x-full\'}\\n      `}>\\n        <div className=\\\"p-6 flex items-center justify-between border-b border-zinc-900\\\">\\n          <Link to=\\\"/\\\" className=\\\"text-2xl font-extrabold text-white tracking-tight\\\">FitByus</Link>\\n          <button className=\\\"md:hidden\\\" onClick={() => setIsSidebarOpen(false)}>\\n            <X className=\\\"w-5 h-5 text-zinc-500\\\" />\\n          </button>\\n        </div>\\n        \\n        <div className=\\\"px-4 py-6 flex-1 overflow-y-auto\\\">\\n          <div className=\\\"flex items-center gap-3 p-3 bg-zinc-900 rounded-xl mb-6 border border-zinc-800\\\">\\n            <div className=\\\"w-10 h-10 bg-brand rounded-full flex items-center justify-center text-black font-bold\\\">\\n              U\\n            </div>\\n            <div>\\n              <p className=\\\"text-sm font-semibold text-white\\\">User Client</p>\\n              <p className=\\\"text-xs text-brand\\\">Premium Plan</p>\\n            </div>\\n          </div>\\n\\n          <nav className=\\\"space-y-1\\\">\\n            {tabs.map((tab) => {\\n              const Icon = tab.icon;\\n              const isActive = activeTab === tab.id;\\n              return (\\n                <button\\n                  key={tab.id}\\n                  onClick={() => {\\n                    setActiveTab(tab.id);\\n                    setIsSidebarOpen(false);\\n                  }}\\n                  className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${\\n                    isActive \\n                      ? \\\"bg-brand/10 text-brand\\\" \\n                      : \\\"text-zinc-400 hover:bg-zinc-900 hover:text-white\\\"\\n                  }`}\\n                >\\n                  <Icon className={`w-5 h-5 ${isActive ? \\\"text-brand\\\" : \\\"text-zinc-500\\\"}`} />\\n                  {tab.label}\\n                </button>\\n              );\\n            })}\\n          </nav>\\n        </div>\\n\\n        <div className=\\\"p-4 border-t border-zinc-900\\\">\\n          <Link to=\\\"/\\\" className=\\\"w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-400 hover:bg-red-500/10 hover:text-red-500 transition-colors\\\">\\n            <LogOut className=\\\"w-5 h-5\\\" />\\n            Sign Out\\n          </Link>\\n        </div>\\n      </aside>\\n\\n      {/* Main Content */}\\n      <main className=\\\"flex-1 flex flex-col min-w-0 overflow-hidden\\\">\\n        <header className=\\\"bg-zinc-950 border-b border-zinc-900 p-4 flex items-center md:hidden\\\">\\n          <button onClick={() => setIsSidebarOpen(true)} className=\\\"p-2 -ml-2 text-zinc-400\\\">\\n            <Menu className=\\\"w-6 h-6\\\" />\\n          </button>\\n          <span className=\\\"font-bold text-lg ml-2 text-white\\\">FitByus</span>\\n        </header>\\n        <div className=\\\"flex-1 overflow-y-auto p-4 md:p-8\\\">\\n          <div className=\\\"max-w-6xl mx-auto\\\">\\n            {renderContent()}\\n          </div>\\n        </div>\\n      </main>\\n    </div>\\n  );\\n}\",\"TargetContent\":\"import { useState } from \\\"react\\\";\\nimport { \\n  User, \\n  Utensils, \\n  Dumbbell, \\n  TrendingUp, \\n  CalendarCheck, \\n  MessageSquare, \\n  CreditCard,\\n  LogOut,\\n  Menu,\\n  X,\\n  Send,\\n  Upload,\\n  Loader2\\n} from \\\"lucide-react\\\";\\nimport { Link } from \\\"react-router-dom\\\";\\nimport { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from \'recharts\';\\nimport { GoogleGenAI, Type } from \\\"@google/genai\\\";\\n\\nconst progressData = [\\n  { name: \'Week 1\', weight: 85 },\\n  { name: \'Week 2\', weight: 84.2 },\\n  { name: \'Week 3\', weight: 83.5 },\\n  { name: \'Week 4\', weight: 82.1 },\\n  { name: \'Week 5\', weight: 81.0 },\\n  { name: \'Week 6\', weight: 79.8 },\\n];\\n\\nexport default function UserDashboard() {\\n  const [activeTab, setActiveTab] = useState(\\\"profile\\\");\\n  const [isSidebarOpen, setIsSidebarOpen] = useState(false);\\n\\n  const [profile, setProfile] = useState({\\n    age: 28,\\n    gender: \'Male\',\\n    weight: 85,\\n    height: 180,\\n    goal: \'Fat Loss\',\\n    activityLevel: \'Moderate\'\\n  });\\n  const [dietPlan, setDietPlan] = useState<any>(null);\\n  const [isGenerating, setIsGenerating] = useState(false);\\n  const [error, setError] = useState(\\\"\\\");\\n\\n  const generateDietPlan = async () => {\\n    setIsGenerating(true);\\n    setError(\\\"\\\");\\n    try {\\n      const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });\\n      const response = await ai.models.generateContent({\\n        model: \\\"gemini-3-flash-preview\\\",\\n        contents: `Generate a personalized diet plan for a ${profile.age} year old ${profile.gender}, weighing ${profile.weight}kg, ${profile.height}cm tall, with a goal of ${profile.goal} and activity level ${profile.activityLevel}. Provide realistic daily calories, macros in grams, a daily meal plan, and a grocery list.`,\\n        config: {\\n          responseMimeType: \\\"application/json\\\",\\n          responseSchema: {\\n            type: Type.OBJECT,\\n            properties: {\\n              calories: { type: Type.NUMBER },\\n              macros: {\\n                type: Type.OBJECT,\\n                properties: {\\n                  protein: { type: Type.NUMBER },\\n                  carbs: { type: Type.NUMBER },\\n                  fat: { type: Type.NUMBER }\\n                },\\n                required: [\\\"protein\\\", \\\"carbs\\\", \\\"fat\\\"]\\n              },\\n              meals: {\\n                type: Type.ARRAY,\\n                items: {\\n                  type: Type.OBJECT,\\n                  properties: {\\n                    name: { type: Type.STRING },\\n                    description: { type: Type.STRING },\\n                    calories: { type: Type.NUMBER }\\n                  },\\n                  required: [\\\"name\\\", \\\"description\\\", \\\"calories\\\"]\\n                }\\n              },\\n              groceryList: {\\n                type: Type.ARRAY,\\n                items: { type: Type.STRING }\\n              }\\n            },\\n            required: [\\\"calories\\\", \\\"macros\\\", \\\"meals\\\", \\\"groceryList\\\"]\\n          }\\n        }\\n      });\\n      if (response.text) {\\n        setDietPlan(JSON.parse(response.text));\\n        setActiveTab(\\\"diet\\\");\\n      }\\n    } catch (err) {\\n      console.error(\\\"Failed to generate diet plan:\\\", err);\\n      setError(\\\"Failed to generate diet plan. Please check your API key and try again.\\\");\\n    } finally {\\n      setIsGenerating(false);\\n    }\\n  };\\n\\n  const tabs = [\\n    { id: \\\"profile\\\", label: \\\"Profile Setup\\\", icon: User },\\n    { id: \\\"diet\\\", label: \\\"AI Diet Generator\\\", icon: Utensils },\\n    { id: \\\"workout\\\", label: \\\"Workout Plan\\\", icon: Dumbbell },\\n    { id: \\\"progress\\\", label: \\\"Progress Tracker\\\", icon: TrendingUp },\\n    { id: \\\"checkin\\\", label: \\\"Weekly Check-in\\\", icon: CalendarCheck },\\n    { id: \\\"chat\\\", label: \\\"Chat with Coach\\\", icon: MessageSquare },\\n    { id: \\\"payment\\\", label: \\\"Payment System\\\", icon: CreditCard },\\n  ];\\n\\n  const renderContent = () => {\\n    switch (activeTab) {\\n      case \\\"profile\\\":\\n        return (\\n          <div className=\\\"space-y-6 max-w-2xl\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Profile Setup</h2>\\n              <p className=\\\"text-zinc-500\\\">Update your personal information to get accurate plans.</p>\\n            </div>\\n            <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 space-y-4\\\">\\n              {error && <div className=\\\"p-3 bg-red-50 text-red-600 rounded-lg text-sm\\\">{error}</div>}\\n              <div className=\\\"grid grid-cols-2 gap-4\\\">\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Age</label>\\n                  <input type=\\\"number\\\" value={profile.age} onChange={e => setProfile({...profile, age: Number(e.target.value)})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\" />\\n                </div>\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Gender</label>\\n                  <select value={profile.gender} onChange={e => setProfile({...profile, gender: e.target.value})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\">\\n                    <option>Male</option>\\n                    <option>Female</option>\\n                    <option>Other</option>\\n                  </select>\\n                </div>\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Weight (kg)</label>\\n                  <input type=\\\"number\\\" value={profile.weight} onChange={e => setProfile({...profile, weight: Number(e.target.value)})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\" />\\n                </div>\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Height (cm)</label>\\n                  <input type=\\\"number\\\" value={profile.height} onChange={e => setProfile({...profile, height: Number(e.target.value)})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\" />\\n                </div>\\n              </div>\\n              <div className=\\\"grid grid-cols-2 gap-4\\\">\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Goal</label>\\n                  <select value={profile.goal} onChange={e => setProfile({...profile, goal: e.target.value})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\">\\n                    <option>Fat Loss</option>\\n                    <option>Muscle Gain</option>\\n                    <option>Maintenance</option>\\n                  </select>\\n                </div>\\n                <div className=\\\"space-y-2\\\">\\n                  <label className=\\\"text-sm font-medium text-zinc-700\\\">Activity Level</label>\\n                  <select value={profile.activityLevel} onChange={e => setProfile({...profile, activityLevel: e.target.value})} className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\">\\n                    <option>Sedentary</option>\\n                    <option>Lightly Active</option>\\n                    <option>Moderate</option>\\n                    <option>Very Active</option>\\n                    <option>Extra Active</option>\\n                  </select>\\n                </div>\\n              </div>\\n              <button \\n                onClick={generateDietPlan}\\n                disabled={isGenerating}\\n                className=\\\"w-full bg-emerald-600 text-white py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors flex items-center justify-center gap-2 disabled:opacity-70\\\"\\n              >\\n                {isGenerating && <Loader2 className=\\\"w-4 h-4 animate-spin\\\" />}\\n                {isGenerating ? \\\"Generating Plan...\\\" : \\\"Save & Generate Diet Plan\\\"}\\n              </button>\\n            </div>\\n          </div>\\n        );\\n      case \\\"diet\\\":\\n        if (!dietPlan) {\\n          return (\\n            <div className=\\\"space-y-6 flex flex-col items-center justify-center h-96 text-center\\\">\\n              <div className=\\\"w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mb-4\\\">\\n                <Utensils className=\\\"w-8 h-8\\\" />\\n              </div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">No Diet Plan Yet</h2>\\n              <p className=\\\"text-zinc-500 max-w-md\\\">Complete your profile and generate your personalized AI diet plan to get started.</p>\\n              <button \\n                onClick={() => setActiveTab(\\\"profile\\\")}\\n                className=\\\"mt-4 bg-emerald-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors\\\"\\n              >\\n                Go to Profile\\n              </button>\\n            </div>\\n          );\\n        }\\n\\n        return (\\n          <div className=\\\"space-y-6\\\">\\n            <div className=\\\"flex justify-between items-start\\\">\\n              <div>\\n                <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">AI Diet Generator</h2>\\n                <p className=\\\"text-zinc-500\\\">Your personalized nutrition plan based on your profile.</p>\\n              </div>\\n              <button \\n                onClick={generateDietPlan}\\n                disabled={isGenerating}\\n                className=\\\"bg-zinc-100 text-zinc-700 px-4 py-2 rounded-lg font-medium hover:bg-zinc-200 transition-colors flex items-center gap-2 text-sm disabled:opacity-70\\\"\\n              >\\n                {isGenerating ? <Loader2 className=\\\"w-4 h-4 animate-spin\\\" /> : <Utensils className=\\\"w-4 h-4\\\" />}\\n                Regenerate\\n              </button>\\n            </div>\\n            \\n            <div className=\\\"grid grid-cols-1 md:grid-cols-3 gap-6\\\">\\n              <div className=\\\"md:col-span-2 space-y-6\\\">\\n                <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 flex items-center justify-between\\\">\\n                  <div>\\n                    <h3 className=\\\"text-lg font-semibold text-zinc-900\\\">Daily Target</h3>\\n                    <p className=\\\"text-zinc-500\\\">Calculated for {profile.goal}</p>\\n                  </div>\\n                  <div className=\\\"text-right\\\">\\n                    <span className=\\\"text-3xl font-bold text-emerald-600\\\">{dietPlan.calories}</span>\\n                    <span className=\\\"text-zinc-500 ml-1\\\">kcal</span>\\n                  </div>\\n                </div>\\n\\n                <div className=\\\"grid grid-cols-3 gap-4\\\">\\n                  <div className=\\\"bg-white p-4 rounded-xl border border-zinc-200 text-center\\\">\\n                    <div className=\\\"text-sm text-zinc-500 mb-1\\\">Protein</div>\\n                    <div className=\\\"text-xl font-bold text-zinc-900\\\">{dietPlan.macros.protein}g</div>\\n                  </div>\\n                  <div className=\\\"bg-white p-4 rounded-xl border border-zinc-200 text-center\\\">\\n                    <div className=\\\"text-sm text-zinc-500 mb-1\\\">Carbs</div>\\n                    <div className=\\\"text-xl font-bold text-zinc-900\\\">{dietPlan.macros.carbs}g</div>\\n                  </div>\\n                  <div className=\\\"bg-white p-4 rounded-xl border border-zinc-200 text-center\\\">\\n                    <div className=\\\"text-sm text-zinc-500 mb-1\\\">Fat</div>\\n                    <div className=\\\"text-xl font-bold text-zinc-900\\\">{dietPlan.macros.fat}g</div>\\n                  </div>\\n                </div>\\n\\n                <div className=\\\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\\\">\\n                  <div className=\\\"p-4 border-b border-zinc-200 bg-zinc-50 font-semibold text-zinc-900\\\">Today\'s Meal Plan</div>\\n                  <div className=\\\"divide-y divide-zinc-100\\\">\\n                    {dietPlan.meals.map((meal: any, idx: number) => (\\n                      <div key={idx} className=\\\"p-4 flex justify-between items-center hover:bg-zinc-50 transition-colors cursor-pointer\\\">\\n                        <div>\\n                          <h4 className=\\\"font-medium text-zinc-900\\\">{meal.name}</h4>\\n                          <p className=\\\"text-sm text-zinc-500\\\">{meal.description}</p>\\n                        </div>\\n                        <span className=\\\"text-sm font-medium text-emerald-600\\\">{meal.calories} kcal</span>\\n                      </div>\\n                    ))}\\n                  </div>\\n                </div>\\n              </div>\\n\\n              <div className=\\\"space-y-6\\\">\\n                <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200\\\">\\n                  <h3 className=\\\"font-semibold text-zinc-900 mb-4\\\">Grocery List</h3>\\n                  <ul className=\\\"space-y-3\\\">\\n                    {dietPlan.groceryList.map((item: string, idx: number) => (\\n                      <li key={idx} className=\\\"flex items-center gap-2 text-sm text-zinc-700\\\">\\n                        <input type=\\\"checkbox\\\" className=\\\"rounded text-emerald-600 focus:ring-emerald-500\\\" /> {item}\\n                      </li>\\n                    ))}\\n                  </ul>\\n                  <button className=\\\"w-full mt-6 text-sm text-emerald-600 font-medium hover:text-emerald-700\\\">\\n                    Export to PDF\\n                  </button>\\n                </div>\\n              </div>\\n            </div>\\n          </div>\\n        );\\n      case \\\"workout\\\":\\n        return (\\n          <div className=\\\"space-y-6\\\">\\n            <div className=\\\"flex justify-between items-end\\\">\\n              <div>\\n                <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Workout Plan</h2>\\n                <p className=\\\"text-zinc-500\\\">Your weekly training schedule.</p>\\n              </div>\\n              <div className=\\\"flex bg-zinc-100 p-1 rounded-lg\\\">\\n                <button className=\\\"px-4 py-1.5 text-sm font-medium bg-white shadow-sm rounded-md text-zinc-900\\\">Gym</button>\\n                <button className=\\\"px-4 py-1.5 text-sm font-medium text-zinc-500 hover:text-zinc-900\\\">Home</button>\\n              </div>\\n            </div>\\n\\n            <div className=\\\"grid grid-cols-1 md:grid-cols-2 gap-6\\\">\\n              {[\'Push Day (Chest, Shoulders, Triceps)\', \'Pull Day (Back, Biceps)\', \'Leg Day (Quads, Hamstrings, Calves)\'].map((day, i) => (\\n                <div key={i} className=\\\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\\\">\\n                  <div className=\\\"p-4 border-b border-zinc-200 bg-zinc-50 flex justify-between items-center\\\">\\n                    <h3 className=\\\"font-semibold text-zinc-900\\\">Day {i + 1}: {day.split(\' \')[0]}</h3>\\n                    <span className=\\\"text-xs font-medium px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full\\\">60 mins</span>\\n                  </div>\\n                  <div className=\\\"p-4 space-y-4\\\">\\n                    <div className=\\\"flex gap-4 items-start\\\">\\n                      <div className=\\\"w-16 h-12 bg-zinc-200 rounded flex-shrink-0 flex items-center justify-center text-zinc-400 text-xs\\\">Video</div>\\n                      <div>\\n                        <h4 className=\\\"text-sm font-medium text-zinc-900\\\">Barbell Bench Press</h4>\\n                        <p className=\\\"text-xs text-zinc-500\\\">3 sets x 8-10 reps</p>\\n                      </div>\\n                    </div>\\n                    <div className=\\\"flex gap-4 items-start\\\">\\n                      <div className=\\\"w-16 h-12 bg-zinc-200 rounded flex-shrink-0 flex items-center justify-center text-zinc-400 text-xs\\\">Video</div>\\n                      <div>\\n                        <h4 className=\\\"text-sm font-medium text-zinc-900\\\">Incline Dumbbell Press</h4>\\n                        <p className=\\\"text-xs text-zinc-500\\\">3 sets x 10-12 reps</p>\\n                      </div>\\n                    </div>\\n                    <button className=\\\"w-full py-2 mt-2 text-sm font-medium text-emerald-600 border border-emerald-200 rounded-lg hover:bg-emerald-50 transition-colors\\\">\\n                      Start Workout\\n                    </button>\\n                  </div>\\n                </div>\\n              ))}\\n            </div>\\n          </div>\\n        );\\n      case \\\"progress\\\":\\n        return (\\n          <div className=\\\"space-y-6\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Progress Tracker</h2>\\n              <p className=\\\"text-zinc-500\\\">Visualize your transformation journey.</p>\\n            </div>\\n\\n            <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 h-80\\\">\\n              <h3 className=\\\"font-semibold text-zinc-900 mb-4\\\">Weight Trend</h3>\\n              <ResponsiveContainer width=\\\"100%\\\" height=\\\"100%\\\">\\n                <LineChart data={progressData}>\\n                  <CartesianGrid strokeDasharray=\\\"3 3\\\" vertical={false} stroke=\\\"#e4e4e7\\\" />\\n                  <XAxis dataKey=\\\"name\\\" axisLine={false} tickLine={false} tick={{fill: \'#71717a\', fontSize: 12}} dy={10} />\\n                  <YAxis domain={[\'dataMin - 2\', \'dataMax + 2\']} axisLine={false} tickLine={false} tick={{fill: \'#71717a\', fontSize: 12}} dx={-10} />\\n                  <Tooltip \\n                    contentStyle={{ borderRadius: \'8px\', border: \'none\', boxShadow: \'0 4px 6px -1px rgb(0 0 0 / 0.1)\' }}\\n                  />\\n                  <Line type=\\\"monotone\\\" dataKey=\\\"weight\\\" stroke=\\\"#10b981\\\" strokeWidth={3} dot={{r: 4, fill: \'#10b981\', strokeWidth: 2, stroke: \'#fff\'}} activeDot={{r: 6}} />\\n                </LineChart>\\n              </ResponsiveContainer>\\n            </div>\\n\\n            <div className=\\\"grid grid-cols-1 md:grid-cols-2 gap-6\\\">\\n              <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200\\\">\\n                <div className=\\\"flex justify-between items-center mb-4\\\">\\n                  <h3 className=\\\"font-semibold text-zinc-900\\\">Progress Photos</h3>\\n                  <button className=\\\"text-sm text-emerald-600 font-medium hover:text-emerald-700 flex items-center gap-1\\\">\\n                    <Upload className=\\\"w-4 h-4\\\" /> Upload\\n                  </button>\\n                </div>\\n                <div className=\\\"grid grid-cols-2 gap-4\\\">\\n                  <div className=\\\"aspect-[3/4] bg-zinc-100 rounded-xl flex items-center justify-center text-zinc-400 text-sm border border-dashed border-zinc-300\\\">\\n                    Week 1 (Front)\\n                  </div>\\n                  <div className=\\\"aspect-[3/4] bg-zinc-100 rounded-xl flex items-center justify-center text-zinc-400 text-sm border border-dashed border-zinc-300\\\">\\n                    Week 6 (Front)\\n                  </div>\\n                </div>\\n              </div>\\n              \\n              <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200\\\">\\n                <h3 className=\\\"font-semibold text-zinc-900 mb-4\\\">Body Measurements</h3>\\n                <div className=\\\"space-y-4\\\">\\n                  <div className=\\\"flex justify-between items-center pb-2 border-b border-zinc-100\\\">\\n                    <span className=\\\"text-zinc-600\\\">Chest</span>\\n                    <span className=\\\"font-medium text-zinc-900\\\">102 cm <span className=\\\"text-emerald-500 text-sm ml-1\\\">(-2cm)</span></span>\\n                  </div>\\n                  <div className=\\\"flex justify-between items-center pb-2 border-b border-zinc-100\\\">\\n                    <span className=\\\"text-zinc-600\\\">Waist</span>\\n                    <span className=\\\"font-medium text-zinc-900\\\">86 cm <span className=\\\"text-emerald-500 text-sm ml-1\\\">(-4cm)</span></span>\\n                  </div>\\n                  <div className=\\\"flex justify-between items-center pb-2 border-b border-zinc-100\\\">\\n                    <span className=\\\"text-zinc-600\\\">Arms</span>\\n                    <span className=\\\"font-medium text-zinc-900\\\">38 cm <span className=\\\"text-zinc-400 text-sm ml-1\\\">(0cm)</span></span>\\n                  </div>\\n                </div>\\n              </div>\\n            </div>\\n          </div>\\n        );\\n      case \\\"checkin\\\":\\n        return (\\n          <div className=\\\"space-y-6 max-w-2xl\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Weekly Check-in</h2>\\n              <p className=\\\"text-zinc-500\\\">Submit your weekly update to your coach.</p>\\n            </div>\\n            \\n            <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 space-y-6\\\">\\n              <div className=\\\"space-y-2\\\">\\n                <label className=\\\"text-sm font-medium text-zinc-700\\\">Current Weight (kg)</label>\\n                <input type=\\\"number\\\" placeholder=\\\"e.g. 80.5\\\" className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\" />\\n              </div>\\n              \\n              <div className=\\\"space-y-2\\\">\\n                <label className=\\\"text-sm font-medium text-zinc-700\\\">Energy Level (1-10)</label>\\n                <input type=\\\"range\\\" min=\\\"1\\\" max=\\\"10\\\" defaultValue=\\\"7\\\" className=\\\"w-full accent-emerald-600\\\" />\\n                <div className=\\\"flex justify-between text-xs text-zinc-500\\\">\\n                  <span>Exhausted</span>\\n                  <span>Energized</span>\\n                </div>\\n              </div>\\n\\n              <div className=\\\"space-y-2\\\">\\n                <label className=\\\"text-sm font-medium text-zinc-700\\\">Sleep Quality (1-10)</label>\\n                <input type=\\\"range\\\" min=\\\"1\\\" max=\\\"10\\\" defaultValue=\\\"6\\\" className=\\\"w-full accent-emerald-600\\\" />\\n                <div className=\\\"flex justify-between text-xs text-zinc-500\\\">\\n                  <span>Poor</span>\\n                  <span>Excellent</span>\\n                </div>\\n              </div>\\n\\n              <div className=\\\"space-y-2\\\">\\n                <label className=\\\"text-sm font-medium text-zinc-700\\\">Upload Photos</label>\\n                <div className=\\\"border-2 border-dashed border-zinc-300 rounded-xl p-8 text-center hover:bg-zinc-50 transition-colors cursor-pointer\\\">\\n                  <Upload className=\\\"w-8 h-8 text-zinc-400 mx-auto mb-2\\\" />\\n                  <p className=\\\"text-sm text-zinc-600\\\">Click to upload front, side, and back photos</p>\\n                </div>\\n              </div>\\n\\n              <div className=\\\"space-y-2\\\">\\n                <label className=\\\"text-sm font-medium text-zinc-700\\\">Notes for Coach</label>\\n                <textarea rows={4} placeholder=\\\"How was your week? Any struggles?\\\" className=\\\"w-full p-2 border border-zinc-300 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none\\\"></textarea>\\n              </div>\\n\\n              <button className=\\\"w-full bg-emerald-600 text-white py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors\\\">\\n                Submit Check-in\\n              </button>\\n            </div>\\n          </div>\\n        );\\n      case \\\"chat\\\":\\n        return (\\n          <div className=\\\"h-[calc(100vh-8rem)] flex flex-col bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\\\">\\n            <div className=\\\"p-4 border-b border-zinc-200 bg-zinc-50 flex items-center gap-3\\\">\\n              <div className=\\\"w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-700 font-bold\\\">\\n                C\\n              </div>\\n              <div>\\n                <h3 className=\\\"font-semibold text-zinc-900\\\">Coach Alex</h3>\\n                <p className=\\\"text-xs text-emerald-600 flex items-center gap-1\\\">\\n                  <span className=\\\"w-2 h-2 rounded-full bg-emerald-500\\\"></span> Online\\n                </p>\\n              </div>\\n            </div>\\n            \\n            <div className=\\\"flex-1 p-4 overflow-y-auto space-y-4 bg-zinc-50/50\\\">\\n              <div className=\\\"flex justify-center\\\">\\n                <span className=\\\"text-xs text-zinc-400 bg-zinc-100 px-2 py-1 rounded-full\\\">Today</span>\\n              </div>\\n              <div className=\\\"flex gap-3 max-w-[80%]\\\">\\n                <div className=\\\"w-8 h-8 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-700 font-bold text-sm flex-shrink-0\\\">\\n                  C\\n                </div>\\n                <div className=\\\"bg-white p-3 rounded-2xl rounded-tl-none shadow-sm border border-zinc-100 text-sm text-zinc-800\\\">\\n                  Hey! I reviewed your check-in. Great progress on the weight loss! Let\'s bump up your carbs slightly on training days. I\'ve updated your diet plan.\\n                </div>\\n              </div>\\n              <div className=\\\"flex gap-3 max-w-[80%] ml-auto flex-row-reverse\\\">\\n                <div className=\\\"w-8 h-8 bg-zinc-800 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0\\\">\\n                  U\\n                </div>\\n                <div className=\\\"bg-emerald-600 p-3 rounded-2xl rounded-tr-none shadow-sm text-sm text-white\\\">\\n                  Awesome, thanks Alex! The workouts have been feeling great too.\\n                </div>\\n              </div>\\n            </div>\\n\\n            <div className=\\\"p-4 border-t border-zinc-200 bg-white\\\">\\n              <div className=\\\"flex gap-2\\\">\\n                <input \\n                  type=\\\"text\\\" \\n                  placeholder=\\\"Type your message...\\\" \\n                  className=\\\"flex-1 p-2 bg-zinc-100 border-transparent rounded-full focus:bg-white focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500 outline-none px-4 text-sm\\\"\\n                />\\n                <button className=\\\"w-10 h-10 bg-emerald-600 text-white rounded-full flex items-center justify-center hover:bg-emerald-700 transition-colors flex-shrink-0\\\">\\n                  <Send className=\\\"w-4 h-4\\\" />\\n                </button>\\n              </div>\\n            </div>\\n          </div>\\n        );\\n      case \\\"payment\\\":\\n        return (\\n          <div className=\\\"space-y-6 max-w-3xl\\\">\\n            <div>\\n              <h2 className=\\\"text-2xl font-bold text-zinc-900\\\">Payment System</h2>\\n              <p className=\\\"text-zinc-500\\\">Manage your subscriptions and coaching plans.</p>\\n            </div>\\n\\n            <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200\\\">\\n              <h3 className=\\\"font-semibold text-zinc-900 mb-4\\\">Current Plan</h3>\\n              <div className=\\\"flex items-center justify-between p-4 border border-emerald-200 bg-emerald-50 rounded-xl\\\">\\n                <div>\\n                  <div className=\\\"font-bold text-emerald-800 text-lg\\\">Free AI Diet Plan</div>\\n                  <p className=\\\"text-sm text-emerald-600\\\">Active</p>\\n                </div>\\n                <div className=\\\"text-2xl font-bold text-emerald-800\\\">\342\202\2710</div>\\n              </div>\\n            </div>\\n\\n            <h3 className=\\\"font-semibold text-zinc-900 pt-4\\\">Upgrade Your Plan</h3>\\n            <div className=\\\"grid grid-cols-1 md:grid-cols-2 gap-4\\\">\\n              <div className=\\\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 hover:border-emerald-500 transition-colors cursor-pointer flex flex-col\\\">\\n                <h4 className=\\\"font-bold text-zinc-900 text-lg\\\">Diet Plan</h4>\\n                <div className=\\\"text-2xl font-bold text-zinc-900 my-2\\\">\342\202\271999</div>\\n                <ul className=\\\"text-sm text-zinc-600 space-y-2 mb-6 flex-1\\\">\\n                  <li>\342\200\242 Custom AI Diet</li>\\n                  <li>\342\200\242 Grocery List</li>\\n                  <li>\342\200\242 Macro Tracking</li>\\n                </ul>\\n                <button className=\\\"w-full py-2 bg-zinc-900 text-white rounded-lg font-medium hover:bg-zinc-800\\\">Select Plan</button>\\n              </div>\\n              \\n              <div className=\\\"bg-zinc-900 p-6 rounded-2xl shadow-md border border-zinc-800 relative flex flex-col\\\">\\n                <div className=\\\"absolute top-0 right-0 bg-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg rounded-tr-xl uppercase tracking-wider\\\">Most Popular</div>\\n                <h4 className=\\\"font-bold text-white text-lg\\\">12 Week Coaching</h4>\\n                <div className=\\\"text-2xl font-bold text-white my-2\\\">\342\202\2714,999</div>\\n                <ul className=\\\"text-sm text-zinc-300 space-y-2 mb-6 flex-1\\\">\\n                  <li>\342\200\242 Everything in Diet Plan</li>\\n                  <li>\342\200\242 Custom Workout Plan</li>\\n                  <li>\342\200\242 Weekly Check-ins</li>\\n                  <li>\342\200\242 Direct Chat with Coach</li>\\n                </ul>\\n                <button className=\\\"w-full py-2 bg-emerald-500 text-white rounded-lg font-medium hover:bg-emerald-600\\\">Upgrade Now</button>\\n              </div>\\n            </div>\\n          </div>\\n        );\\n      default:\\n        return null;\\n    }\\n  };\\n\\n  return (\\n    <div className=\\\"min-h-screen bg-zinc-50 flex\\\">\\n      {/* Mobile Sidebar Overlay */}\\n      {isSidebarOpen && (\\n        <div \\n          className=\\\"fixed inset-0 bg-black/20 z-20 md:hidden\\\"\\n          onClick={() => setIsSidebarOpen(false)}\\n        />\\n      )}\\n\\n      {/* Sidebar */}\\n      <aside className={`\\n        fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-zinc-200 transform transition-transform duration-200 ease-in-out md:relative md:translate-x-0\\n        ${isSidebarOpen ? \'translate-x-0\' : \'-translate-x-full\'}\\n      `}>\\n        <div className=\\\"p-6 flex items-center justify-between\\\">\\n          <Link to=\\\"/\\\" className=\\\"text-2xl font-extrabold text-zinc-900 tracking-tight\\\">FitByus</Link>\\n          <button className=\\\"md:hidden\\\" onClick={() => setIsSidebarOpen(false)}>\\n            <X className=\\\"w-5 h-5 text-zinc-500\\\" />\\n          </button>\\n        </div>\\n        \\n        <div className=\\\"px-4 pb-6\\\">\\n          <div className=\\\"flex items-center gap-3 p-3 bg-zinc-50 rounded-xl mb-6 border border-zinc-100\\\">\\n            <div className=\\\"w-10 h-10 bg-zinc-800 rounded-full flex items-center justify-center text-white font-bold\\\">\\n              U\\n            </div>\\n            <div>\\n              <p className=\\\"text-sm font-semibold text-zinc-900\\\">User Client</p>\\n              <p className=\\\"text-xs text-zinc-500\\\">Free Plan</p>\\n            </div>\\n          </div>\\n\\n          <nav className=\\\"space-y-1\\\">\\n            {tabs.map((tab) => {\\n              const Icon = tab.icon;\\n              const isActive = activeTab === tab.id;\\n              return (\\n                <button\\n                  key={tab.id}\\n                  onClick={() => {\\n                    setActiveTab(tab.id);\\n                    setIsSidebarOpen(false);\\n                  }}\\n                  className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${\\n                    isActive \\n                      ? \\\"bg-emerald-50 text-emerald-700\\\" \\n                      : \\\"text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900\\\"\\n                  }`}\\n                >\\n                  <Icon className={`w-5 h-5 ${isActive ? \\\"text-emerald-600\\\" : \\\"text-zinc-400\\\"}`} />\\n                  {tab.label}\\n                </button>\\n              );\\n            })}\\n          </nav>\\n        </div>\\n\\n        <div className=\\\"absolute bottom-0 left-0 right-0 p-4 border-t border-zinc-100\\\">\\n          <Link to=\\\"/\\\" className=\\\"w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900 transition-colors\\\">\\n            <LogOut className=\\\"w-5 h-5 text-zinc-400\\\" />\\n            Sign Out\\n          </Link>\\n        </div>\\n      </aside>\\n\\n      {/* Main Content */}\\n      <main className=\\\"flex-1 flex flex-col min-w-0 overflow-hidden\\\">\\n        <header className=\\\"bg-white border-b border-zinc-200 p-4 flex items-center md:hidden\\\">\\n          <button onClick={() => setIsSidebarOpen(true)} className=\\\"p-2 -ml-2 text-zinc-600\\\">\\n            <Menu className=\\\"w-6 h-6\\\" />\\n          </button>\\n          <span className=\\\"font-bold text-lg ml-2\\\">FitByus</span>\\n        </header>\\n        <div className=\\\"flex-1 overflow-y-auto p-4 md:p-8\\\">\\n          {renderContent()}\\n        </div>\\n      </main>\\n    </div>\\n  );\\n}\",\"TargetFile\":\"/src/pages/UserDashboard.tsx\",\"toolSummary\":\"Update UserDashboard with new components\"}"
      thought_signature: ""
    }
