      replacement_content: "import { useState } from \"react\";\nimport { \n  Users, \n  DollarSign, \n  UserCheck, \n  Image as ImageIcon,\n  LogOut,\n  Menu,\n  X,\n  Search,\n  MoreVertical,\n  CheckCircle,\n  XCircle,\n  Upload\n} from \"lucide-react\";\nimport { Link } from \"react-router-dom\";\nimport { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, BarChart, Bar } from \'recharts\';\n\nconst revenueData = [\n  { name: \'Jan\', revenue: 4000 },\n  { name: \'Feb\', revenue: 3000 },\n  { name: \'Mar\', revenue: 2000 },\n  { name: \'Apr\', revenue: 2780 },\n  { name: \'May\', revenue: 1890 },\n  { name: \'Jun\', revenue: 2390 },\n  { name: \'Jul\', revenue: 3490 },\n];\n\nexport default function AdminDashboard() {\n  const [activeTab, setActiveTab] = useState(\"revenue\");\n  const [isSidebarOpen, setIsSidebarOpen] = useState(false);\n\n  const tabs = [\n    { id: \"revenue\", label: \"Revenue Dashboard\", icon: DollarSign },\n    { id: \"users\", label: \"User Management\", icon: Users },\n    { id: \"coaches\", label: \"Coach Management\", icon: UserCheck },\n    { id: \"gallery\", label: \"Transformation Gallery\", icon: ImageIcon },\n  ];\n\n  const renderContent = () => {\n    switch (activeTab) {\n      case \"revenue\":\n        return (\n          <div className=\"space-y-6\">\n            <div>\n              <h2 className=\"text-2xl font-bold text-zinc-900\">Revenue Dashboard</h2>\n              <p className=\"text-zinc-500\">Overview of your business performance.</p>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 flex flex-col justify-between\">\n                <div className=\"flex items-center gap-3 mb-4\">\n                  <div className=\"w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600\">\n                    <DollarSign className=\"w-5 h-5\" />\n                  </div>\n                  <h3 className=\"font-semibold text-zinc-600\">Total Revenue</h3>\n                </div>\n                <div>\n                  <div className=\"text-3xl font-bold text-zinc-900\">\342\202\2711,24,500</div>\n                  <p className=\"text-sm text-emerald-600 font-medium mt-1\">+12.5% from last month</p>\n                </div>\n              </div>\n\n              <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 flex flex-col justify-between\">\n                <div className=\"flex items-center gap-3 mb-4\">\n                  <div className=\"w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600\">\n                    <Users className=\"w-5 h-5\" />\n                  </div>\n                  <h3 className=\"font-semibold text-zinc-600\">Active Clients</h3>\n                </div>\n                <div>\n                  <div className=\"text-3xl font-bold text-zinc-900\">342</div>\n                  <p className=\"text-sm text-emerald-600 font-medium mt-1\">+24 new this week</p>\n                </div>\n              </div>\n\n              <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 flex flex-col justify-between\">\n                <div className=\"flex items-center gap-3 mb-4\">\n                  <div className=\"w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center text-orange-600\">\n                    <UserCheck className=\"w-5 h-5\" />\n                  </div>\n                  <h3 className=\"font-semibold text-zinc-600\">Monthly Subscriptions</h3>\n                </div>\n                <div>\n                  <div className=\"text-3xl font-bold text-zinc-900\">128</div>\n                  <p className=\"text-sm text-zinc-500 font-medium mt-1\">Recurring revenue: \342\202\27164,000/mo</p>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"bg-white p-6 rounded-2xl shadow-sm border border-zinc-200 h-96\">\n              <h3 className=\"font-semibold text-zinc-900 mb-6\">Revenue Trend</h3>\n              <ResponsiveContainer width=\"100%\" height=\"100%\">\n                <BarChart data={revenueData}>\n                  <CartesianGrid strokeDasharray=\"3 3\" vertical={false} stroke=\"#e4e4e7\" />\n                  <XAxis dataKey=\"name\" axisLine={false} tickLine={false} tick={{fill: \'#71717a\', fontSize: 12}} dy={10} />\n                  <YAxis axisLine={false} tickLine={false} tick={{fill: \'#71717a\', fontSize: 12}} dx={-10} />\n                  <Tooltip \n                    cursor={{fill: \'#f4f4f5\'}}\n                    contentStyle={{ borderRadius: \'8px\', border: \'none\', boxShadow: \'0 4px 6px -1px rgb(0 0 0 / 0.1)\' }}\n                  />\n                  <Bar dataKey=\"revenue\" fill=\"#10b981\" radius={[4, 4, 0, 0]} />\n                </BarChart>\n              </ResponsiveContainer>\n            </div>\n          </div>\n        );\n      case \"users\":\n        return (\n          <div className=\"space-y-6\">\n            <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n              <div>\n                <h2 className=\"text-2xl font-bold text-zinc-900\">User Management</h2>\n                <p className=\"text-zinc-500\">Manage clients and assign coaches.</p>\n              </div>\n              <div className=\"relative w-full sm:w-64\">\n                <Search className=\"w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400\" />\n                <input \n                  type=\"text\" \n                  placeholder=\"Search clients...\" \n                  className=\"w-full pl-9 pr-4 py-2 border border-zinc-200 rounded-lg text-sm focus:ring-2 focus:ring-emerald-500 outline-none\"\n                />\n              </div>\n            </div>\n\n            <div className=\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\">\n              <div className=\"overflow-x-auto\">\n                <table className=\"w-full text-sm text-left\">\n                  <thead className=\"text-xs text-zinc-500 uppercase bg-zinc-50 border-b border-zinc-200\">\n                    <tr>\n                      <th className=\"px-6 py-4 font-medium\">Client Name</th>\n                      <th className=\"px-6 py-4 font-medium\">Plan</th>\n                      <th className=\"px-6 py-4 font-medium\">Goal</th>\n                      <th className=\"px-6 py-4 font-medium\">Assigned Coach</th>\n                      <th className=\"px-6 py-4 font-medium text-right\">Actions</th>\n                    </tr>\n                  </thead>\n                  <tbody className=\"divide-y divide-zinc-100\">\n                    {[\n                      { name: \"Rahul Sharma\", plan: \"12 Week Coaching\", goal: \"Fat Loss\", coach: \"Alex\" },\n                      { name: \"Priya Patel\", plan: \"Premium Coaching\", goal: \"Muscle Gain\", coach: \"Unassigned\" },\n                      { name: \"Amit Kumar\", plan: \"Diet Plan\", goal: \"Maintenance\", coach: \"N/A\" },\n                      { name: \"Neha Singh\", plan: \"12 Week Coaching\", goal: \"Fat Loss\", coach: \"Sarah\" },\n                    ].map((client, i) => (\n                      <tr key={i} className=\"hover:bg-zinc-50 transition-colors\">\n                        <td className=\"px-6 py-4 font-medium text-zinc-900\">{client.name}</td>\n                        <td className=\"px-6 py-4\">\n                          <span className={`px-2 py-1 rounded-full text-xs font-medium ${\n                            client.plan.includes(\'Coaching\') ? \'bg-indigo-100 text-indigo-700\' : \'bg-emerald-100 text-emerald-700\'\n                          }`}>\n                            {client.plan}\n                          </span>\n                        </td>\n                        <td className=\"px-6 py-4 text-zinc-600\">{client.goal}</td>\n                        <td className=\"px-6 py-4\">\n                          {client.coach === \"Unassigned\" ? (\n                            <select className=\"text-sm border border-zinc-200 rounded p-1 bg-white text-orange-600 font-medium focus:ring-2 focus:ring-emerald-500 outline-none\">\n                              <option value=\"\">Assign Coach</option>\n                              <option value=\"alex\">Alex</option>\n                              <option value=\"sarah\">Sarah</option>\n                            </select>\n                          ) : (\n                            <span className={client.coach === \"N/A\" ? \"text-zinc-400\" : \"text-zinc-900 font-medium\"}>\n                              {client.coach}\n                            </span>\n                          )}\n                        </td>\n                        <td className=\"px-6 py-4 text-right\">\n                          <button className=\"text-zinc-400 hover:text-zinc-900\">\n                            <MoreVertical className=\"w-4 h-4\" />\n                          </button>\n                        </td>\n                      </tr>\n                    ))}\n                  </tbody>\n                </table>\n              </div>\n            </div>\n          </div>\n        );\n      case \"coaches\":\n        return (\n          <div className=\"space-y-6\">\n            <div>\n              <h2 className=\"text-2xl font-bold text-zinc-900\">Coach Management</h2>\n              <p className=\"text-zinc-500\">Approve coaches and set their commission rates.</p>\n            </div>\n\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n              <div className=\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\">\n                <div className=\"p-4 border-b border-zinc-200 bg-zinc-50 font-semibold text-zinc-900\">\n                  Pending Approvals\n                </div>\n                <div className=\"divide-y divide-zinc-100\">\n                  {[\n                    { name: \"Vikram Singh\", exp: \"5 years\", cert: \"ACE Certified\" },\n                    { name: \"Anjali Desai\", exp: \"3 years\", cert: \"ISSA Certified\" },\n                  ].map((coach, i) => (\n                    <div key={i} className=\"p-4 flex items-center justify-between\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"w-10 h-10 bg-zinc-100 rounded-full flex items-center justify-center text-zinc-600 font-bold\">\n                          {coach.name.charAt(0)}\n                        </div>\n                        <div>\n                          <h4 className=\"font-medium text-zinc-900\">{coach.name}</h4>\n                          <p className=\"text-xs text-zinc-500\">{coach.exp} exp \342\200\242 {coach.cert}</p>\n                        </div>\n                      </div>\n                      <div className=\"flex gap-2\">\n                        <button className=\"p-1.5 text-emerald-600 bg-emerald-50 rounded hover:bg-emerald-100\">\n                          <CheckCircle className=\"w-5 h-5\" />\n                        </button>\n                        <button className=\"p-1.5 text-red-600 bg-red-50 rounded hover:bg-red-100\">\n                          <XCircle className=\"w-5 h-5\" />\n                        </button>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              <div className=\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden\">\n                <div className=\"p-4 border-b border-zinc-200 bg-zinc-50 font-semibold text-zinc-900\">\n                  Active Coaches\n                </div>\n                <div className=\"divide-y divide-zinc-100\">\n                  {[\n                    { name: \"Alex\", clients: 45, comm: 30 },\n                    { name: \"Sarah\", clients: 32, comm: 35 },\n                  ].map((coach, i) => (\n                    <div key={i} className=\"p-4 flex items-center justify-between\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-700 font-bold\">\n                          {coach.name.charAt(0)}\n                        </div>\n                        <div>\n                          <h4 className=\"font-medium text-zinc-900\">{coach.name}</h4>\n                          <p className=\"text-xs text-zinc-500\">{coach.clients} Active Clients</p>\n                        </div>\n                      </div>\n                      <div className=\"flex items-center gap-2\">\n                        <label className=\"text-xs text-zinc-500\">Comm. %</label>\n                        <input \n                          type=\"number\" \n                          defaultValue={coach.comm} \n                          className=\"w-16 p-1 text-sm border border-zinc-200 rounded text-center focus:ring-2 focus:ring-emerald-500 outline-none\"\n                        />\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            </div>\n          </div>\n        );\n      case \"gallery\":\n        return (\n          <div className=\"space-y-6\">\n            <div className=\"flex justify-between items-center\">\n              <div>\n                <h2 className=\"text-2xl font-bold text-zinc-900\">Transformation Gallery</h2>\n                <p className=\"text-zinc-500\">Manage before/after photos for marketing.</p>\n              </div>\n              <button className=\"bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-emerald-700 transition-colors flex items-center gap-2 text-sm\">\n                <Upload className=\"w-4 h-4\" /> Upload New\n              </button>\n            </div>\n\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n              {[1, 2, 3, 4].map((item) => (\n                <div key={item} className=\"bg-white rounded-2xl shadow-sm border border-zinc-200 overflow-hidden group\">\n                  <div className=\"aspect-video bg-zinc-100 flex items-center justify-center text-zinc-400 border-b border-zinc-200 relative\">\n                    <div className=\"absolute inset-0 flex\">\n                      <div className=\"w-1/2 border-r border-white/50 flex items-center justify-center bg-zinc-200/50\">Before</div>\n                      <div className=\"w-1/2 flex items-center justify-center bg-zinc-300/50\">After</div>\n                    </div>\n                  </div>\n                  <div className=\"p-4 flex justify-between items-center\">\n                    <div>\n                      <h4 className=\"font-medium text-zinc-900\">Client Transformation {item}</h4>\n                      <p className=\"text-xs text-zinc-500\">12 Week Program \342\200\242 -15kg</p>\n                    </div>\n                    <div className=\"flex items-center gap-2\">\n                      <label className=\"flex items-center gap-1 text-xs font-medium text-zinc-600 cursor-pointer\">\n                        <input type=\"checkbox\" defaultChecked={item < 3} className=\"rounded text-emerald-600 focus:ring-emerald-500\" />\n                        Use in Ads\n                      </label>\n                    </div>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        );\n      default:\n        return null;\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-zinc-50 flex\">\n      {/* Mobile Sidebar Overlay */}\n      {isSidebarOpen && (\n        <div \n          className=\"fixed inset-0 bg-black/20 z-20 md:hidden\"\n          onClick={() => setIsSidebarOpen(false)}\n        />\n      )}\n\n      {/* Sidebar */}\n      <aside className={`\n        fixed inset-y-0 left-0 z-30 w-64 bg-zinc-900 text-zinc-300 transform transition-transform duration-200 ease-in-out md:relative md:translate-x-0\n        ${isSidebarOpen ? \'translate-x-0\' : \'-translate-x-full\'}\n      `}>\n        <div className=\"p-6 flex items-center justify-between\">\n          <Link to=\"/\" className=\"text-2xl font-extrabold text-white tracking-tight\">FitByus Admin</Link>\n          <button className=\"md:hidden\" onClick={() => setIsSidebarOpen(false)}>\n            <X className=\"w-5 h-5 text-zinc-400\" />\n          </button>\n        </div>\n        \n        <div className=\"px-4 pb-6\">\n          <div className=\"flex items-center gap-3 p-3 bg-zinc-800 rounded-xl mb-6 border border-zinc-700\">\n            <div className=\"w-10 h-10 bg-emerald-500 rounded-full flex items-center justify-center text-white font-bold\">\n              A\n            </div>\n            <div>\n              <p className=\"text-sm font-semibold text-white\">Admin User</p>\n              <p className=\"text-xs text-zinc-400\">Superadmin</p>\n            </div>\n          </div>\n\n          <nav className=\"space-y-1\">\n            {tabs.map((tab) => {\n              const Icon = tab.icon;\n              const isActive = activeTab === tab.id;\n              return (\n                <button\n                  key={tab.id}\n                  onClick={() => {\n                    setActiveTab(tab.id);\n                    setIsSidebarOpen(false);\n                  }}\n                  className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors ${\n                    isActive \n                      ? \"bg-zinc-800 text-white\" \n                      : \"text-zinc-400 hover:bg-zinc-800 hover:text-white\"\n                  }`}\n                >\n                  <Icon className={`w-5 h-5 ${isActive ? \"text-emerald-500\" : \"text-zinc-500\"}`} />\n                  {tab.label}\n                </button>\n              );\n            })}\n          </nav>\n        </div>\n\n        <div className=\"absolute bottom-0 left-0 right-0 p-4 border-t border-zinc-800\">\n          <Link to=\"/\" className=\"w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-zinc-400 hover:bg-zinc-800 hover:text-white transition-colors\">\n            <LogOut className=\"w-5 h-5 text-zinc-500\" />\n            Sign Out\n          </Link>\n        </div>\n      </aside>\n\n      {/* Main Content */}\n      <main className=\"flex-1 flex flex-col min-w-0 overflow-hidden\">\n        <header className=\"bg-white border-b border-zinc-200 p-4 flex items-center md:hidden\">\n          <button onClick={() => setIsSidebarOpen(true)} className=\"p-2 -ml-2 text-zinc-600\">\n            <Menu className=\"w-6 h-6\" />\n          </button>\n          <span className=\"font-bold text-lg ml-2\">FitByus Admin</span>\n        </header>\n        <div className=\"flex-1 overflow-y-auto p-4 md:p-8\">\n          {renderContent()}\n        </div>\n      </main>\n    </div>\n  );\n}\n"
    }
